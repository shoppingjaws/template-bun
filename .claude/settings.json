{
	"permissions": {
		"allow": [
		],
		"ask": [
			"Edit(package.json)",
			"Edit(mise.toml)"
		]
	},
	"hooks": {
		"PostToolUse": [
      {
        "matcher": "Bash(container-use checkout:*)",
        "hooks": [
          {
            "type": "command",
            "command": "bun run format"
          },
          {
            "type": "command",
            "command": "bun run lint"
          },
          {
            "type": "command",
            "command": "bun run typecheck"
          }
        ]
      }
    ]
	}
}
